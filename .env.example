# Plantilla de variables de entorno.
# Copiar este archivo como .env y rellenar con valores reales.

GITHUB_USER=tu-usuario-github

NODE_ENV=production
APP_NAME=BK-CRM
APP_URL=http://192.168.X.X:8081
APP_ROOT_DOMAIN=192.168.X.X
NEXT_PUBLIC_APP_ROOT_DOMAIN=192.168.X.X
DEFAULT_LOCALE=es

AUTH_SECRET=cambia-esto-con-openssl-rand-base64-32
AUTH_TRUST_HOST=true
AUTH_URL=http://192.168.X.X:8081

POSTGRES_USER=bkcrm
POSTGRES_PASSWORD=cambia-esta-clave
POSTGRES_DB=bkcrm
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://bkcrm:cambia-esta-clave@db:5432/bkcrm?schema=public

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

MINIO_ROOT_USER=bkcrm
MINIO_ROOT_PASSWORD=cambia-esta-clave-minio
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=bkcrm
MINIO_PUBLIC_URL=http://192.168.X.X:9010

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
AI_MONTHLY_CAP_USD=50

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="BK-CRM <no-reply@bk-crm.local>"

WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
GOOGLE_MAPS_API_KEY=

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

LOG_LEVEL=info
